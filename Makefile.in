# Enable secondary expansions, needed for font compilation rules
.SECONDEXPANSION:

SRC := $(abspath $(SRCDIR))
OBJ := $(abspath $(CURDIR))

ifeq ($(filter s,$(MAKEFLAGS)),s)
MAKEFLAGS += --quiet --no-print-directory
--quiet? := --quiet
else
MFLAGS += V=1 VERBOSE=1
-v? := -v
--verbose? := --verbose
endif

SHELL := /bin/bash

##
## General/global config
##

# We expect the configure script to conditionally set the following:
#   SRCDIR          - Path to source
#   BUILD_NAME      - Name of the build for manifests etc.
#   STEAMRT_IMAGE   - Name of the docker image to use for building
#
TARGET_ARCH ?= x86_64

ifeq ($(TARGET_ARCH),x86_64)
	STEAMRT_IMAGE ?= registry.gitlab.steamos.cloud/proton/steamrt4/sdk/x86_64:4.0.20260331.220802-0
else ifeq ($(TARGET_ARCH),arm64)
	STEAMRT_IMAGE ?= registry.gitlab.steamos.cloud/proton/steamrt4/sdk/arm64-llvm:4.0.20260331.220802-0
else
	ARCHS := $(error Unknown TARGET_ARCH=$(TARGET_ARCH))
endif

ifeq ($(SRCDIR),)
	foo := $(error SRCDIR not set, do not include Makefile.in directly, run ./configure.sh to generate Makefile)
endif

SOURCE_DATE_EPOCH ?= $(shell date +%s)
MFLAGS += BASE_SOURCE_DATE_EPOCH=$(SOURCE_DATE_EPOCH)
unexport SOURCE_DATE_EPOCH

DST_BASE := $(OBJ)/dist
DST_DIR := $(DST_BASE)/files
DST_LIBDIR := $(DST_DIR)/lib
DIST_PREFIX := $(DST_DIR)/share/default_pfx/
DIST_PREFIX_ARM64 := $(DST_DIR)/share/default_pfx_arm64/
DIST_VERSION := $(DST_BASE)/version
DEPLOY_DIR := ./deploy
REDIST_DIR := ./redist

HOST_CFLAGS    ?= -O2 -march=nocona -mtune=core-avx2
CCOS_CFLAGS    := $(HOST_CFLAGS) -pipe -mno-avx512f
i386_CFLAGS    := -mstackrealign $(CCOS_CFLAGS) -mfpmath=sse
x86_64_CFLAGS  := -mcmodel=small $(CCOS_CFLAGS) -mfpmath=sse
HOST_RUSTFLAGS   ?= -Copt-level=3 -Ctarget-cpu=nocona
i386_RUSTFLAGS   := $(HOST_RUSTFLAGS)
x86_64_RUSTFLAGS := $(HOST_RUSTFLAGS)
aarch64_CFLAGS := -march=armv8.2-a -mtune=cortex-x3
arm64ec_CFLAGS := -march=armv8.2-a -mtune=cortex-x3
aarch64_RUSTFLAGS := -Copt-level=3 -Ctarget-cpu=armv8.2-a
arm64ec_RUSTFLAGS := -Copt-level=3 -Ctarget-cpu=armv8.2-a

CFLAGS  = -fwrapv -fno-strict-aliasing
CFLAGS += -ffunction-sections -fdata-sections -fno-omit-frame-pointer
CFLAGS += -ffile-prefix-map=$(CCACHE_BASEDIR)=.

ifneq ($(SUPPRESS_WARNINGS),)
	CFLAGS += -w
endif

ifneq ($(USE_LTO),1)
	GST_LTO :=
	FFMPEG_LTO :=
else
	GST_LTO := -Db_lto=true
	FFMPEG_LTO := --enable-lto
endif

$(DST_DIR):
	mkdir -p $@

ifeq ($(CONTAINER),1) # inside the container

HOST_ARCH := $(shell uname -m)
ARCHS := i386-windows x86_64-windows

TARGET_ARCH ?= x86_64

ifeq ($(TARGET_ARCH),x86_64)
	ARCHS += x86_64-unix
ifneq ($(ENABLE_WOW64),1)
	ARCHS += i386-unix
endif
else ifeq ($(TARGET_ARCH),arm64)
	ARCHS += aarch64-unix aarch64-windows arm64ec-windows
else
	ARCHS := $(error Unknown TARGET_ARCH=$(TARGET_ARCH))
endif

unix_ARCHS = $(subst -unix,,$(filter %-unix,$(ARCHS)))
windows_ARCHS = $(subst -windows,,$(filter %-windows,$(ARCHS)))

i386_SOURCE_DATE_EPOCH := $(BASE_SOURCE_DATE_EPOCH)
x86_64_SOURCE_DATE_EPOCH := $(shell expr $(BASE_SOURCE_DATE_EPOCH) - 10)
aarch64_SOURCE_DATE_EPOCH := $(shell expr $(BASE_SOURCE_DATE_EPOCH) - 20)
arm64ec_SOURCE_DATE_EPOCH := $(shell expr $(BASE_SOURCE_DATE_EPOCH) - 30)

ifeq ($(shell cc --version|grep 'clang'),)
	# GCC-specific flags
	# required because SteamRT's GCC14 statically links with libstdc++ and this
	# avoids re-exporting of its symbols in every .so created this way
	CFLAGS += -Wl,--exclude-libs=libstdc++.a
	TOOLCHAIN_PREFIX :=
	OBJCOPY_FLAGS  := -p
	MINGW_TYPE := gcc
	i386_CFLAGS += -s -mno-avx -mno-avx2
	i386_CFLAGS += -fvect-cost-model=cheap -fno-semantic-interposition -fipa-pta
	x86_64_CFLAGS += -s -mno-avx -mno-avx2
	x86_64_CFLAGS += -fvect-cost-model=cheap -fno-semantic-interposition -fipa-pta
	i386_SANITY_FLAGS := -mpreferred-stack-boundary=2
else
	# CLANG-specific flags
	TOOLCHAIN_PREFIX := llvm-
	OBJCOPY_FLAGS  :=
	MINGW_TYPE := clang
	# TODO: move this to a configure option
	i386_SANITY_FLAGS := -mstack-alignment=4
endif

OBJCOPY := $(TOOLCHAIN_PREFIX)objcopy

ifneq ($(UNSTRIPPED_BUILD),)
    STRIP :=
    INSTALL_PROGRAM_FLAGS :=
    MESON_STRIP_ARG :=
else
    STRIP := $(TOOLCHAIN_PREFIX)strip
    INSTALL_PROGRAM_FLAGS := -s
    MESON_STRIP_ARG := --strip
endif

# all, all-dist and dist are basically synonyms
.PHONY: all all-dist dist
all: all-dist | $(DST_DIR)
all-dist: | $(DST_DIR)
dist: all

J = $(patsubst -j%,%,$(filter -j%,$(MAKEFLAGS)))

include $(SRC)/make/utility.mk
include $(SRC)/make/rules-source.mk
include $(SRC)/make/rules-common.mk
include $(SRC)/make/rules-makedep.mk
include $(SRC)/make/rules-meson.mk
include $(SRC)/make/rules-cmake.mk
include $(SRC)/make/rules-autoconf.mk
include $(SRC)/make/rules-configure.mk
include $(SRC)/make/rules-winemaker.mk
include $(SRC)/make/rules-wine-requests.mk
include $(SRC)/make/rules-wine-tools.mk
include $(SRC)/make/rules-cargo.mk


##
## patches
##

$(eval $(call rules-source,patches,$(SRCDIR)/patches))


##
## meson
##

$(eval $(call rules-source,meson,$(SRCDIR)/meson))


##
## dav1d
##

DAV1D_MESON_ARGS = \
	-Denable_tools=false \
	-Denable_tests=false

$(eval $(call rules-source,dav1d,$(SRCDIR)/dav1d))
$(eval $(call rules-meson,dav1d,i386,unix))
$(eval $(call rules-meson,dav1d,x86_64,unix))
$(eval $(call rules-meson,dav1d,aarch64,unix))


##
## libxml2
##

LIBXML2_MESON_ARGS := \
	-Ddocs=disabled \
	-Dicu=disabled \
	-Dlegacy=enabled \
	-Dpython=disabled

$(eval $(call rules-source,libxml2,$(SRCDIR)/libxml2))
$(eval $(call rules-meson,libxml2,i386,unix))
$(eval $(call rules-meson,libxml2,x86_64,unix))
$(eval $(call rules-meson,libxml2,aarch64,unix))


ifneq ($(WITHOUT_WAYLAND_LIBS),1)

##
## xkbcommon
##

LIBXKBCOMMON_MESON_ARGS := \
	-Denable-xkbregistry=true \
	-Denable-docs=false \
	-Denable-x11=false \
	-Denable-bash-completion=false \
	-Denable-wayland=false

LIBXKBCOMMON_DEPENDS = libxml2

$(eval $(call rules-source,libxkbcommon,$(SRCDIR)/libxkbcommon))
$(eval $(call rules-meson,libxkbcommon,i386,unix))
$(eval $(call rules-meson,libxkbcommon,x86_64,unix))
$(eval $(call rules-meson,libxkbcommon,aarch64,unix))


##
## wayland-protocols
##

WAYLAND_PROTOCOLS_MESON_ARGS := \
	-Dtests=false

$(eval $(call rules-source,wayland-protocols,$(SRCDIR)/wayland-protocols))
$(eval $(call rules-meson,wayland-protocols,i386,unix))
$(eval $(call rules-meson,wayland-protocols,x86_64,unix))
$(eval $(call rules-meson,wayland-protocols,aarch64,unix))

endif # WITHOUT_WAYLAND_LIBS


ifneq ($(WITHOUT_LIBPCAP),1)

##
## libpcap
##

LIBPCAP_CONFIGURE_ARGS := \
	--enable-shared \
	--disable-static \
	--disable-usb \
	--disable-netmap \
	--disable-bluetooth \
	--disable-dbus \
	--disable-rdma \
	--with-pcap=linux \
	--without-libnl

$(eval $(call rules-source,libpcap,$(SRCDIR)/libpcap))
$(eval $(call rules-configure,libpcap,i386,unix))
$(eval $(call rules-configure,libpcap,x86_64,unix))
$(eval $(call rules-configure,libpcap,aarch64,unix))

$(OBJ)/.libpcap-post-source:
	cd "$(LIBPCAP_SRC)" && autoreconf -fiv
	touch $@

endif # WITHOUT_LIBPCAP


##
## nghttp2
##

NGHTTP2_CONFIGURE_ARGS = \
	--disable-examples \
	--disable-python-bindings \
	--enable-lib-only

$(eval $(call rules-source,nghttp2,$(SRCDIR)/nghttp2))
$(eval $(call rules-configure,nghttp2,i386,unix))
$(eval $(call rules-configure,nghttp2,x86_64,unix))
$(eval $(call rules-configure,nghttp2,aarch64,unix))

$(OBJ)/.nghttp2-post-source:
	cd "$(NGHTTP2_SRC)" && autoreconf -fiv
	touch $@


##
## libsoup
##

LIBSOUP_MESON_ARGS = \
	-Ddocs=disabled \
	-Dautobahn=disabled \
	-Dtls_check=false

LIBSOUP_DEPENDS = nghttp2

$(eval $(call rules-source,libsoup,$(SRCDIR)/libsoup))
$(eval $(call rules-meson,libsoup,i386,unix))
$(eval $(call rules-meson,libsoup,x86_64,unix))
$(eval $(call rules-meson,libsoup,aarch64,unix))


##
## gst-orc
##

GST_ORC_MESON_ARGS := \
	-Dorc-test=disabled

GST_ORC_MESON_ARGS += \
	$(GST_LTO) \
	-Dexamples=disabled \
	-Dtests=disabled \
	-Dbenchmarks=disabled \

$(eval $(call rules-source,gst_orc,$(SRCDIR)/gst-orc))
$(eval $(call rules-meson,gst_orc,i386,unix))
$(eval $(call rules-meson,gst_orc,x86_64,unix))
$(eval $(call rules-meson,gst_orc,aarch64,unix))


##
## gstreamer
##

GSTREAMER_MESON_ARGS := \
	-Dgst_parse=false \
	-Dbenchmarks=disabled \
	-Dtools=disabled \
	-Dbash-completion=disabled

GSTREAMER_MESON_ARGS += \
	$(GST_LTO) \
	-Dptp-helper-permissions=capabilities \
	-Ddbghelp=disabled \
	-Dintrospection=disabled \
	-Dgobject-cast-checks=disabled \
	-Dglib-asserts=disabled \
	-Dglib-checks=disabled \
	-Dnls=disabled \
	-Dexamples=disabled \
	-Dtests=disabled \
	-Ddoc=disabled \
	-Dgst_parse=true \

GSTREAMER_LDFLAGS = -lm
GSTREAMER_DEPENDS = gst_orc

$(eval $(call rules-source,gstreamer,$(SRCDIR)/gstreamer/subprojects/gstreamer))
$(eval $(call rules-meson,gstreamer,i386,unix))
$(eval $(call rules-meson,gstreamer,x86_64,unix))
$(eval $(call rules-meson,gstreamer,aarch64,unix))


##
## graphene
##

GRAPHENE_MESON_ARGS := \
	-Dtests=false \
	-Dintrospection=disabled \
	-Dinstalled_tests=false

$(eval $(call rules-source,graphene,$(SRCDIR)/graphene))
$(eval $(call rules-meson,graphene,i386,unix))
$(eval $(call rules-meson,graphene,x86_64,unix))
$(eval $(call rules-meson,graphene,aarch64,unix))


##
## gst-plugins-base
##

GST_BASE_MESON_ARGS := \
	-Dauto_features=disabled \
	-Dadder=enabled \
	-Dapp=enabled \
	-Daudioconvert=enabled \
	-Daudioresample=enabled \
	-Dogg=enabled \
	-Dopus=enabled \
	-Dpbtypes=enabled \
	-Dplayback=enabled \
	-Dtheora=enabled \
	-Dtypefind=enabled \
	-Dvideoconvertscale=enabled \
	-Dvorbis=enabled \
	-Dorc=enabled \
	-Dx11=enabled \
	-Dgl=enabled \
	-Dgl-graphene=enabled \
	-Dgl_platform=glx,egl \
	--wrap-mode nodownload \

GST_BASE_MESON_ARGS += \
	$(GST_LTO) \
	-Dintrospection=disabled \
	-Dgobject-cast-checks=disabled \
	-Dglib-asserts=disabled \
	-Dglib-checks=disabled \
	-Dnls=disabled \
	-Dexamples=disabled \
	-Dtests=disabled \
	-Ddoc=disabled \
	-Dtools=disabled \
	-Drawparse=enabled \
	-Dgl_winsys=surfaceless,x11,wayland,egl \

GST_BASE_LDFLAGS = -lm
GST_BASE_DEPENDS = gst_orc graphene gstreamer
ifneq ($(WITHOUT_WAYLAND_LIBS),1)
GST_BASE_DEPENDS += wayland-protocols
endif
GST_BASE_HOST_DEPENDS = gst_orc

$(eval $(call rules-source,gst_base,$(SRCDIR)/gstreamer/subprojects/gst-plugins-base))
$(eval $(call rules-meson,gst_base,i386,unix))
$(eval $(call rules-meson,gst_base,x86_64,unix))
$(eval $(call rules-meson,gst_base,aarch64,unix))


