##
## FFmpeg
##

FFMPEG_CONFIGURE_ARGS := \
	--enable-shared \
	--disable-static \
	--disable-everything \
	--disable-programs \
	--disable-doc \
	--disable-inline-asm \
	--enable-demuxer=matroska \

