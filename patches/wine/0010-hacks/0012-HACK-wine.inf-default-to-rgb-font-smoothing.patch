From eee80799ff48ab633b7fc50669f890c45d846544 Mon Sep 17 00:00:00 2001
From: Stelios Tsampas <loathingkernel@gmail.com>
Date: Sun, 26 Apr 2026 17:24:02 +0300
Subject: [PATCH 12/15] HACK: wine.inf: default to 'rgb' font smoothing

---
 loader/wine.inf.in | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/loader/wine.inf.in b/loader/wine.inf.in
index aece31f8dc1..e7fc3479300 100644
--- a/loader/wine.inf.in
+++ b/loader/wine.inf.in
@@ -63,6 +63,7 @@ AddReg=\
     Debugger,\
     DirectX,\
     Fonts,\
+    FontSmooth,\
     LicenseInformation,\
     MCI,\
     Misc,\
@@ -520,6 +521,12 @@ HKLM,%FontSubStr%,"Times New Roman Greek,161",,"Times New Roman,161"
 HKLM,%FontSubStr%,"Times New Roman TUR,162",,"Times New Roman,162"
 HKLM,System\CurrentControlSet\Hardware Profiles\Current\Software\Fonts,"LogPixels",0x10003,0x00000060
 
+[FontSmooth]
+HKCU,Control Panel\Desktop,"FontSmoothing",,"2"
+HKCU,Control Panel\Desktop,"FontSmoothingGamma",0x10001,0x00000578
+HKCU,Control Panel\Desktop,"FontSmoothingOrientation",0x10001,0x00000001
+HKCU,Control Panel\Desktop,"FontSmoothingType",0x10001,0x00000002
+
 [MCI]
 HKLM,%Mci32Str%,"AVIVideo",,"mciavi32.dll"
 HKLM,%Mci32Str%,"CDAudio",,"mcicda.dll"
